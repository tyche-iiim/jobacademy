<script>
    // Scroll Reveal Intersection Observer
    const revealCallback = (entries, observer) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('active');
            }
        });
    };

    const revealObserver = new IntersectionObserver(revealCallback, {
        threshold: 0.15
    });

    document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

    // Sticky Header & Logo Animation
    const header = document.getElementById('main-header');
    
    // Parallax & Scroll Effects
    window.addEventListener('scroll', () => {
        const scrolled = window.scrollY;
        
        // Header class toggle
        if (scrolled > 50) {
            header.classList.add('scrolled', 'py-2', 'shadow-md');
            header.classList.remove('py-4');
        } else {
            header.classList.remove('scrolled', 'shadow-md');
            header.classList.add('py-4');
        }

        // Parallax effects
        const heroImg = document.getElementById('hero-image-container');
        const heroBg = document.getElementById('hero-bg-accent');
        
        if (heroImg) {
            heroImg.style.transform = `translateY(${scrolled * 0.15}px) rotate(2deg)`;
        }
        if (heroBg) {
            heroBg.style.transform = `translateY(${scrolled * -0.2}px) translateX(25%)`;
        }
    });
</script>
